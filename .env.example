# Copiar a .env y completar. Este archivo unico lo cargan tanto el backend (server/,
# via `npm run dev`) como el frontend (client/, variables VITE_*).

# --- HTTP ---
PORT=4000

# --- Base de datos (PostgreSQL via Prisma) ---
# url: conexion pooled usada en runtime
DATABASE_URL=postgresql://fenrir:fenrir@localhost:5432/fenrir?schema=public
# directUrl: conexion directa usada por las migraciones de Prisma
DIRECT_URL=postgresql://fenrir:fenrir@localhost:5432/fenrir?schema=public

# --- On-chain (Sepolia) ---
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/REEMPLAZAR
SEPOLIA_CHAIN_ID=11155111
# Direccion del FenrirFactory desplegado (ancla). Los project/token/governor se
# descubren dinamicamente a partir del evento ProjectCreated.
FENRIR_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
# Bloque de despliegue del factory: punto de partida del backfill inicial.
INGESTION_START_BLOCK=0
# Confirmaciones a esperar antes de avanzar el cursor (resistencia a reorg).
INGESTION_CONFIRMATIONS=5
# Tamano de pagina del backfill por queryFilter.
INGESTION_BACKFILL_BATCH=2000

# --- Storage de reportes de hito ---
# local => archivos en disco (REPORT_STORAGE_LOCAL_DIR), reportHash = SHA-256 canonico.
# ipfs  => archivos + manifest pineados en IPFS (Pinata); reportHash = CID del manifest
#          (digest sha2-256 en bytes32). Sobrevive a la caida del frontend.
REPORT_STORAGE_DRIVER=local
REPORT_STORAGE_LOCAL_DIR=./.data/reports
# Base publica con la que se construye la reportUrl que el developer pone on-chain.
PUBLIC_BASE_URL=http://localhost:4000
# Si se define, la reportUrl on-chain apunta a la pagina del proyecto en el frontend
# (link legible); si no, cae al endpoint /reports/:id del backend.
FRONTEND_URL=http://localhost:5173

# Pinata (solo con REPORT_STORAGE_DRIVER=ipfs).
# JWT desde https://app.pinata.cloud/developers/api-keys (token completo eyJ...).
PINATA_JWT=
# Gateway publico (o tu gateway dedicado .mypinata.cloud).
PINATA_GATEWAY=https://gateway.pinata.cloud

# --- Auth por firma de wallet ---
# Minutos de validez de un nonce de login.
AUTH_NONCE_TTL_MINUTES=10

# --- Logging (pino) ---
# Nivel minimo: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info
# true => salida legible (pino-pretty) para desarrollo; false => JSON de una linea.
LOG_PRETTY=false

# --- Frontend (client/, Vite) ---
# Base de la API REST del backend (server/).
VITE_API_URL=http://localhost:4000
# Red on-chain: Sepolia.
VITE_SEPOLIA_CHAIN_ID=11155111
# Direccion del FenrirFactory desplegado en Sepolia.
VITE_FENRIR_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
# true => sirve las lecturas con MSW (sin backend). false => API real.
VITE_USE_MOCK=false
