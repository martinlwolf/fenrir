# Copiar a contracts/.env y completar. NUNCA commitear el .env con la private key real.

# Mismo endpoint RPC de Sepolia que usa el backend (Alchemy/Infura/etc).
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/TU_API_KEY

# Private key de la wallet que paga el deploy (con SepoliaETH de un faucet).
# Con o sin "0x". Es solo para Sepolia/testnet; jamas una key con fondos reales.
PRIVATE_KEY=
